# PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/costly"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Bearer secret for the scheduled sweep (Vercel Cron sends it automatically
# when CRON_SECRET is set; any other scheduler must send
# "Authorization: Bearer <value>")
CRON_SECRET="change-me"

# JWT signing secret for web-user sessions (jose, HS256). Use a long random
# value in production, e.g. `openssl rand -base64 48`.
JWT_SECRET="change-me-to-a-long-random-string"

# Public base URL of this app — used for Stripe Checkout success/cancel
# redirects (must be a publicly reachable https URL in production).
APP_BASE_URL="http://localhost:3000"

# Live privacy-policy URL (Google Play requires one for Usage Access apps).
# Served by this app at /privacy; point the Play listing here.
PRIVACY_POLICY_URL="http://localhost:3000/privacy"

# NOTE: DEVICE_API_SECRET (the old shared build-time secret) is retired in
# Phase 1 — devices now authenticate with a per-device x-device-secret issued
# by /api/device/link and stored hashed in the Device table.
