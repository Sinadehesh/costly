// COSTLY v2 — Prisma schema
//
// Money convention: ALL monetary values are integer cents (Stripe's unit).
// Never floats, never Decimal euros — €30.00 is stored as 3000.
//
// Stripe constraint that shapes this schema: a single PaymentIntent cannot
// be partially captured while keeping the remainder on hold — a partial
// capture auto-releases the rest. So the 20/80 split uses TWO PaymentIntents
// per session: a "burn" intent (20%, captured immediately, off-session) and
// a "purgatory" intent (80%, manual-capture hold, cancelled on redemption
// success or captured on deadline expiry).
//
// The deletion fee ("dead man's switch") is a third off-session charge,
// triggered by the heartbeat sweep when the device goes silent for 2
// consecutive 12h ping windows (>24h) while a commitment contract is still
// inside its lock-in period.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  ACTIVE   // timer running on device; heartbeats arriving
  HOLD     // session ended: 20% captured, 80% on pre-auth hold, redemption pending
  RELEASED // walking goal met in time → purgatory hold cancelled, funds released
  CAPTURED // 24h deadline missed → purgatory hold captured, funds lost
}

enum RedemptionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ContractStatus {
  ACTIVE    // inside lock-in; dead man's switch armed
  COMPLETED // lock-in served in full; heartbeats no longer enforced
  CANCELLED // user ran the (free) cancel flow after lock-in expiry
  BREACHED  // heartbeats went dark during lock-in → deletion fee charged
}

// Phase 2 — Settle Up. An off-session charge that fails (SCA required, card
// declined) flips the account to PAYMENT_FAILED; the heartbeat endpoint then
// returns 402 and the client hard-locks into "Settle Up" until resolved.
enum AccountStatus {
  ACTIVE
  PAYMENT_FAILED
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String   @unique

  // ── Rate: the user states what one hour of their life is worth ─────────
  hourlyRateCents        Int // set explicitly at onboarding, no guessing
  penaltyRateCentsPerMin Int // hourlyRateCents / 60, stored to keep billing stable

  // ── Safety rails ───────────────────────────────────────────────────────
  sessionCapCents Int @default(3000) // hard financial stop per session (€30)
  idleTimeoutSecs Int @default(60)   // pause timer after N s without a scroll event

  // ── Dead man's switch ──────────────────────────────────────────────────
  // The companion app pings /api/device/heartbeat every 12h. The sweep
  // treats 2 consecutive missed pings (>24h of silence) during an ACTIVE
  // contract's lock-in as deletion/permission-revocation → breach charge.
  lastHeartbeatAt DateTime?

  // ── Stripe ─────────────────────────────────────────────────────────────
  stripeCustomerId      String? @unique
  stripePaymentMethodId String? // saved via SetupIntent; required for off-session charges

  currency String @default("eur")

  // ── Account standing (Phase 2: Settle Up) ──────────────────────────────
  accountStatus   AccountStatus @default(ACTIVE)
  paymentFailedAt DateTime?
  settleUpUrl     String? // Stripe hosted-invoice / payment URL the Settle Up screen opens

  // ── Device linking (Phase 1) ───────────────────────────────────────────
  // Short-lived 6-digit OTP the (JWT-authenticated) web dashboard issues; the
  // Android client exchanges it at /api/device/link for a per-device secret.
  // Stored HASHED, never plaintext. @unique so a given active code maps to at
  // most one user (the link endpoint sends only the OTP, no userId) — the
  // endpoint regenerates on the rare collision and owns TTL + attempt limits.
  deviceLinkOtpHash      String?   @unique
  deviceLinkOtpExpiresAt DateTime?

  // ── Daily laziness penalty (Phase 3) ────────────────────────────────────
  // Below dailyStepGoal for a completed day → the cron charges
  // lazinessPenaltyCents off-session. Defaults so existing users are covered.
  dailyStepGoal        Int @default(8000)
  lazinessPenaltyCents Int @default(200) // €2

  // IANA tz id (e.g. "Europe/Berlin"), refreshed on every step sync. The cron
  // uses it to only charge for a local day that has safely concluded (+buffer),
  // so no one is billed before their day is actually over.
  timezone String @default("UTC")

  sessions        Session[]
  anchorItems     AnchorItem[]
  contracts       CommitmentContract[]
  devices         Device[]
  dailyActivities DailyActivity[]
}

// Phase 3 — one row per user per calendar day. Step totals are pushed by the
// Android HealthSyncWorker (Health Connect is on-device only) and read by the
// nightly /api/jobs/evaluate-steps cron. penaltyEvaluatedAt is the DB-side
// idempotency guard: the cron only looks at rows where it's null, and stamps
// it once the day is settled, so a re-fired cron skips already-done days.
model DailyActivity {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  day    DateTime @db.Date // the calendar day this covers (device-local)
  steps  Int      @default(0)
  source String?

  // Laziness evaluation, written by the cron.
  penaltyEvaluatedAt           DateTime?
  penaltyChargeCents           Int? // amount charged (0 = goal met / exempt / unchargeable)
  stripePenaltyPaymentIntentId String?   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, day])
  @@index([day, penaltyEvaluatedAt])
}

// Phase 1 — one row per linked Android device. The raw x-device-secret is
// returned to the client exactly ONCE at link time and never persisted; only
// its SHA-256 hash lives here, so a DB leak can't authenticate a device. The
// header-enforcement wrapper hashes the incoming secret, looks it up by
// secretHash, rejects if revokedAt is set, and derives userId from the row —
// which is how userId leaves the request bodies entirely. Supports multiple
// devices per user + soft revocation.
model Device {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  secretHash String  @unique // sha256(x-device-secret); raw never stored
  label      String? // optional, e.g. "Pixel 8"

  createdAt  DateTime  @default(now())
  lastSeenAt DateTime?
  revokedAt  DateTime? // soft-revoke without losing history

  @@index([userId])
}

// The escalating hostage ladder: 5 items at rising price tiers
// (1: coffee €5 … 5: PS5 €500). The live meter taunts when the running
// session penalty crosses an item's exact price:
// "Thank you for buying us [Product Name]."
model AnchorItem {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  name       String // "AirPods"
  priceCents Int    // 25000
  tierLevel  Int    // 1..5, ascending prices enforced at the API layer
  emoji      String?

  @@unique([userId, tierLevel])
  @@index([userId])
}

// The "Breach of Contract / Deletion Fee" agreement. A separate table
// (not User columns) because contracts renew: each lock-in period is its
// own row with its own fee, consent evidence, and terminal state. The
// requirement's DeletionFeeAmount / ContractLockinEndDate live here;
// LastHeartbeatPing lives on User (heartbeats are per-device, not
// per-contract).
model CommitmentContract {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // €0..€1000. €0 is allowed ("Not Recommended") — a €0 breach still
  // flips status to BREACHED, it just charges nothing.
  deletionFeeCents Int

  lockinStartsAt DateTime @default(now())
  lockinEndsAt   DateTime // ContractLockinEndDate

  // Consent evidence for the off-session breach charge — Stripe disputes
  // on a "you charged me for deleting an app" chargeback are won or lost
  // on this record.
  acceptedAt   DateTime
  termsVersion String

  status ContractStatus @default(ACTIVE)

  breachedAt                   DateTime?
  stripeBreachPaymentIntentId  String?   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // heartbeat sweep: WHERE status = ACTIVE (then compare user.lastHeartbeatAt)
  @@index([status, lockinEndsAt])
  @@index([userId, status])
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  appPackage String    // vice app, e.g. "com.instagram.android"
  startTime  DateTime  @default(now())
  endTime    DateTime?

  // Active (billable) time only. Idle gaps — no TYPE_VIEW_SCROLLED event for
  // idleTimeoutSecs — are excluded by the heartbeat endpoint, so this is the
  // authoritative billable duration, not endTime - startTime.
  totalActiveSeconds Int       @default(0)
  lastScrollEventAt  DateTime?

  totalPenaltyCents Int     @default(0)
  burnCents         Int     @default(0) // 20% — permanently captured
  purgatoryCents    Int     @default(0) // 80% — held, redeemable
  capReached        Boolean @default(false)

  // Taunt mechanic: highest anchor tier whose price this session's meter
  // has already crossed (and taunted). Ensures each tier taunts exactly
  // once per session even though heartbeats arrive every ~30s.
  lastTauntTier Int @default(0)

  status SessionStatus @default(ACTIVE)

  stripeBurnPaymentIntentId      String? @unique
  stripePurgatoryPaymentIntentId String? @unique

  redemption RedemptionTask?

  @@index([userId, status])
  @@index([status, endTime])
}

model RedemptionTask {
  id        String  @id @default(cuid())
  sessionId String  @unique
  session   Session @relation(fields: [sessionId], references: [id])

  // 2:1 sweat equity — requiredWalkingMinutes = 2 × billable scroll minutes
  requiredWalkingMinutes  Int
  completedWalkingMinutes Int       @default(0)
  deadline                DateTime  // session.endTime + 24h
  lastHealthSyncAt        DateTime?
  healthSource            String?   // "health_connect" | "healthkit"

  status RedemptionStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // expiry sweep: WHERE status = PENDING AND deadline < now()
  @@index([status, deadline])
}

// Idempotency ledger for Stripe webhooks — insert-or-skip on event.id so
// retried deliveries never double-process a capture or release.
model WebhookEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())
}
