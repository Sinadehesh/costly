<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Networking: the spy, the heartbeat, and the health sync all POST home. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Re-arm WorkManager after reboot so the dead man's switch survives a
         restart. Missing this = a phone that reboots overnight looks "deleted". -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Foreground-service-adjacent + expedited work reliability. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- The live meter overlay + the heuristic spy engine both run as
         foreground services. Android 15+ requires a persistent overlay to be
         backed by one, hence the SPECIAL_USE type. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Heuristic spy engine (Play-compliant, no AccessibilityService):
         Usage Access detects the foreground app, the gyroscope detects the
         physical motion of doomscrolling. PACKAGE_USAGE_STATS is granted by
         the user in Settings, not at install — the manifest entry only
         declares intent. -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />

    <!-- Health Connect: read walking + steps for the last 24h. -->
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />

    <!-- Android 14+ routes Health Connect permission requests through this. -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>

    <application
        android:name=".CostlyApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Costly">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Costly">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Health Connect blocks permission requests unless the app
                 declares a privacy-policy/rationale target. This action covers
                 Android <14; the ViewPermissionUsageActivity alias below covers
                 Android 14+. Both must exist. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Health Connect shows this activity as the app's privacy policy target
             when the user reviews granted permissions. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".ui.MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- THE HEURISTIC SPY ENGINE. A foreground service (no accessibility):
             polls Usage Access for the foreground app and reads the gyroscope
             to detect doomscrolling. Started from the arming UI once Usage
             Access is granted. -->
        <service
            android:name=".spy.HeuristicSpyService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Detects when a blocked app is open and whether the user is actively doomscrolling, to run the penalty meter the user contracted for." />
        </service>

        <!-- The live meter overlay window host. -->
        <service
            android:name=".overlay.CostlyOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Draws the live scrolling-cost meter over the blocked app the user opened." />
        </service>

        <!-- Re-schedule workers after reboot. -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- We schedule WorkManager ourselves from CostlyApp; disable the default
             initializer so there's a single source of truth. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>
</manifest>
