<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Networking: the spy, the heartbeat, and the health sync all POST home. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Re-arm WorkManager after reboot so the dead man's switch survives a
         restart. Missing this = a phone that reboots overnight looks "deleted". -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Foreground-service-adjacent + expedited work reliability. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- The live meter overlay + the heuristic spy engine both run as
         foreground services. Android 15+ requires a persistent overlay to be
         backed by one, hence the SPECIAL_USE type.
         PLAY REVIEW: FOREGROUND_SERVICE_SPECIAL_USE requires a declaration in
         the Play Console (App content → Foreground service permissions). The
         justification for each service is its PROPERTY_SPECIAL_USE_FGS_SUBTYPE
         value below; neither service does background work that fits a standard
         FGS type (dataSync/health/etc.), so specialUse is the correct choice. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Heuristic spy engine (Play-compliant, no AccessibilityService):
         Usage Access detects the foreground app, the gyroscope detects the
         physical motion of doomscrolling. PACKAGE_USAGE_STATS is an appops
         permission GRANTED BY THE USER in Settings (not at install), so the
         manifest entry only declares intent — hence tools:ignore, which
         silences lint's "signature/privileged permission" warning.
         PLAY REVIEW: Usage Access / "Sensitive app usage data" must be
         declared and justified in the Play Console. Justification: Costly is a
         self-monitoring anti-doomscrolling tool; the user explicitly grants
         Usage Access so the app can see WHICH of the user's own blocked apps is
         foregrounded in order to run the penalty meter they contracted for. No
         usage data leaves the device except the derived, per-session billable
         seconds the user agreed to. A live privacy policy is linked in the
         listing (see web /privacy). -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />

    <!-- Health Connect: read walking + steps for the last 24h. -->
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />

    <queries>
        <!-- Android 14+ routes Health Connect permission requests through this. -->
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
        <!-- Package visibility (Android 11+) so we can resolve the target apps'
             UIDs for per-app network engagement. Specific packages, NOT
             QUERY_ALL_PACKAGES — the Play-friendly way. -->
        <package android:name="com.instagram.android" />
        <package android:name="com.zhiliaoapp.musically" />
        <package android:name="com.ss.android.ugc.trill" />
    </queries>

    <application
        android:name=".CostlyApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Costly">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Costly">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Health Connect blocks permission requests unless the app
                 declares a privacy-policy/rationale target. This action covers
                 Android <14; the ViewPermissionUsageActivity alias below covers
                 Android 14+. Both must exist. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Health Connect shows this activity as the app's privacy policy target
             when the user reviews granted permissions. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".ui.MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- THE HEURISTIC SPY ENGINE. A foreground service (no accessibility):
             polls Usage Access for the foreground app and reads the gyroscope
             to detect doomscrolling. Started from the arming UI once Usage
             Access is granted.
             PLAY REVIEW: specialUse is required because this is a continuous,
             user-initiated monitoring service that maps to none of the standard
             FGS types. The PROPERTY_SPECIAL_USE_FGS_SUBTYPE below is the exact
             justification string to paste into the Play Console declaration. -->
        <service
            android:name=".spy.HeuristicSpyService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Detects when a blocked app is open and whether the user is actively doomscrolling, to run the penalty meter the user contracted for." />
        </service>

        <!-- The live meter overlay window host.
             PLAY REVIEW: second specialUse FGS; its subtype string below is the
             Play Console justification. Backs the SYSTEM_ALERT_WINDOW overlay,
             which Android 15+ requires a foreground service to keep alive. -->
        <service
            android:name=".overlay.CostlyOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Draws the live scrolling-cost meter over the blocked app the user opened." />
        </service>

        <!-- Re-schedule workers after reboot. -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- We schedule WorkManager ourselves from CostlyApp; disable the default
             initializer so there's a single source of truth. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>
</manifest>
