<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only manifest overlay. Manifest merging folds this networkSecurityConfig
  attribute onto the <application> for debug builds only, so the release APK
  never gets a cleartext exemption.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
